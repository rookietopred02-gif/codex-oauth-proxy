{
  "name": "codex-pro-max",
  "version": "0.1.1",
  "private": true,
  "description": "Local OAuth reverse proxy for Codex/OpenAI-compatible APIs",
  "author": "fi",
  "type": "module",
  "main": "electron/main.cjs",
  "productName": "codex-pro-max",
  "scripts": {
    "start": "node src/server.js",
    "desktop:dev": "node scripts/run-electron.mjs .",
    "build:runner": "node scripts/build-temp-mail-runner.mjs",
    "build:cloudflared": "node scripts/build-cloudflared-bundles.mjs",
    "build:desktop-resources": "npm run build:runner && npm run build:cloudflared",
    "dist:win": "npm run build:desktop-resources && node scripts/dist-electron-win.mjs",
    "dist:mac": "npm run build:desktop-resources && electron-builder --mac dmg --universal",
    "dist:linux": "npm run build:desktop-resources && electron-builder --linux AppImage --x64",
    "lint": "node scripts/lint.mjs",
    "format:check": "node scripts/check-format.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:smoke": "node --test tests/app-server.test.js tests/cloudflared-service.test.js tests/config-service.test.js tests/dashboard-auth.test.js tests/electron-runtime-paths.test.js tests/lifecycle-control.test.js",
    "test": "node --test",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test:smoke"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "local.codexpromax.desktop",
    "productName": "codex-pro-max",
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "package.json",
      "README.md",
      "!test/**/*",
      "!tests/**/*"
    ],
    "extraResources": [
      {
        "from": "build-resources/temp-mail-runner",
        "to": "temp-mail-runner",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build-resources/cloudflared",
        "to": "cloudflared",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Development"
    }
  }
}
