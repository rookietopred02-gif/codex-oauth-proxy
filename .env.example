HOST=127.0.0.1
PORT=8787

# codex-oauth (default) | profile-store | custom-oauth
AUTH_MODE=codex-oauth

# openai-v1(label=>codex-chatgpt) | gemini-v1beta | anthropic-v1
UPSTREAM_MODE=codex-chatgpt
UPSTREAM_BASE_URL=https://chatgpt.com/backend-api

# --- Gemini protocol (UPSTREAM_MODE=gemini-v1beta) ---
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Optional: leave empty to use local Gemini-compatible facade (Codex OAuth backend)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-pro

# --- Anthropic protocol (UPSTREAM_MODE=anthropic-v1) ---
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# Optional: leave empty to use local Anthropic-compatible facade (Codex OAuth backend)
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# defaults used when mapping /v1/responses -> /codex/responses
CODEX_DEFAULT_MODEL=gpt-5.3-codex
CODEX_DEFAULT_INSTRUCTIONS=You are a helpful assistant.
CODEX_DEFAULT_REASONING_EFFORT=adaptive

# --- Model Router (Antigravity-style) ---
# exact > wildcard(*) > system fallback
MODEL_ROUTER_ENABLED=true
# JSON object, example:
# {"gpt-5.3-codex":"gemini-2.5-pro","gpt-4*":"gemini-2.5-flash","claude-*":"claude-sonnet-4-6"}
MODEL_ROUTER_MAPPINGS=

# --- AUTH_MODE=profile-store ---
# Defaults to %USERPROFILE%\.codex-oauth-proxy\auth-profiles.json
PROFILE_AUTH_STORE_PATH=
PROFILE_AUTH_ID=openai-codex:default

# --- AUTH_MODE=codex-oauth (built-in ChatGPT OAuth) ---
CODEX_OAUTH_CALLBACK_BIND_HOST=127.0.0.1
CODEX_OAUTH_CALLBACK_PORT=1455
CODEX_OAUTH_CALLBACK_PATH=/auth/callback
CODEX_OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
CODEX_OAUTH_ORIGINATOR=pi
CODEX_TOKEN_STORE_PATH=./data/codex-oauth-store.json

# --- Codex preheat (manual trigger) ---
# Manual preheat only (triggered from dashboard button)
CODEX_PREHEAT_COOLDOWN_SECONDS=1200
CODEX_PREHEAT_BATCH_SIZE=2
CODEX_PREHEAT_MIN_PRIMARY_REMAINING=5
CODEX_PREHEAT_MIN_SECONDARY_REMAINING=5
CODEX_PREHEAT_HISTORY_PATH=./data/codex-preheat-history.json

# --- AUTH_MODE=custom-oauth (optional fallback mode) ---
OAUTH_AUTHORIZE_URL=
OAUTH_TOKEN_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://127.0.0.1:8787/auth/callback
OAUTH_SCOPES=openid profile email offline_access
TOKEN_STORE_PATH=./data/auth-store.json
